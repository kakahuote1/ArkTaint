{
    "name": "arktaint",
    "version": "1.0.0",
    "description": "Taint analysis framework for HarmonyOS",
    "main": "out/src/index.js",
    "scripts": {
        "build": "tsc",
        "test": "jest",
        "test:context": "node out/tests/test_context.js",
        "test:full": "node out/tests/test_full_dataset.js",
        "test:manifest": "node out/tests/test_dataset_by_manifest.js",
        "test:dev": "node out/tests/test_dataset_by_manifest.js --manifest tests/manifests/dev.list --k 1",
        "test:holdout": "node out/tests/test_dataset_by_manifest.js --manifest tests/manifests/holdout.list --k 1",
        "test:metamorphic": "node out/tests/test_metamorphic.js --manifest tests/manifests/metamorphic_seed.list --k 1",
        "test:metamorphic:v2": "node out/tests/test_metamorphic_v2.js --manifest tests/manifests/metamorphic_seed_v2.list --sourceDir tests/demo/metamorphic_seed_v2 --k 1",
        "test:metamorphic:v3": "node out/tests/test_metamorphic_v3.js --manifest tests/manifests/metamorphic_seed_v3.list --sourceDir tests/demo/metamorphic_seed_v2 --k 1",
        "test:smoke": "node out/tests/test_real_project_smoke.js --manifest tests/manifests/smoke_projects.json --k 1 --maxEntries 12",
        "test:smoke:external": "node out/tests/test_real_project_smoke.js --manifest tests/manifests/phase78_external_projects.json --k 1 --maxEntries 40 --outputDir tmp/real_projects/smoke_external",
        "test:project-rule-delta": "node out/tests/test_project_rule_unknown_reduction.js",
        "test:smoke:label": "node out/tests/test_smoke_labeling.js --report tmp/phase43/smoke_report.json --outputDir tmp/phase43 --sampleSize 20",
        "test:rules": "node out/tests/test_rules_schema.js --default rules/default.rules.json",
        "test:rules-highrisk": "node out/tests/test_rule_validator_high_risk.js",
        "test:rules:layers": "node out/tests/test_rule_layering.js",
        "test:callee-resolver": "node out/tests/test_callee_resolver.js",
        "test:complex-calls": "node out/tests/test_complex_calls.js --sourceDir tests/demo/complex_calls --k 1",
        "test:source-sink-rules": "node out/tests/test_source_sink_rules.js --sourceDir tests/demo/context_sensitive --default tests/rules/minimal.rules.json --project tests/rules/source_sink_only.rules.json --k 1",
        "test:harmony-lifecycle": "node out/tests/test_harmony_lifecycle.js --sourceDir tests/demo/harmony_lifecycle --default tests/rules/minimal.rules.json --framework rules/framework.rules.json --project tests/rules/harmony_lifecycle_sink_only.rules.json --k 1",
        "test:harmony-appstorage": "node out/tests/test_harmony_appstorage.js --sourceDir tests/demo/harmony_appstorage --default tests/rules/minimal.rules.json --project tests/rules/harmony_appstorage.rules.json --k 1",
        "test:harmony-appstorage:baseline": "node out/tests/test_harmony_appstorage.js --sourceDir tests/demo/harmony_appstorage --default tests/rules/minimal.rules.json --project tests/rules/harmony_appstorage.rules.json --k 1 --disableModeling",
        "test:harmony-localstorage": "node out/tests/test_harmony_appstorage.js --sourceDir tests/demo/harmony_localstorage --default tests/rules/minimal.rules.json --project tests/rules/harmony_localstorage.rules.json --k 1",
        "test:harmony-localstorage:baseline": "node out/tests/test_harmony_appstorage.js --sourceDir tests/demo/harmony_localstorage --default tests/rules/minimal.rules.json --project tests/rules/harmony_localstorage.rules.json --k 1 --disableModeling",
        "test:harmony-persistentstorage": "node out/tests/test_harmony_appstorage.js --sourceDir tests/demo/harmony_persistentstorage --default tests/rules/minimal.rules.json --project tests/rules/harmony_persistentstorage.rules.json --k 1",
        "test:harmony-persistentstorage:baseline": "node out/tests/test_harmony_appstorage.js --sourceDir tests/demo/harmony_persistentstorage --default tests/rules/minimal.rules.json --project tests/rules/harmony_persistentstorage.rules.json --k 1 --disableModeling",
        "test:harmony-event-activation": "node out/tests/test_harmony_event_activation.js --sourceDir tests/demo/harmony_event_activation --default tests/rules/minimal.rules.json --project tests/rules/harmony_event_activation.rules.json --k 1",
        "test:harmony-emitter": "node out/tests/test_harmony_emitter.js --sourceDir tests/demo/harmony_emitter --default tests/rules/minimal.rules.json --project tests/rules/harmony_emitter.rules.json --k 1",
        "test:harmony-state": "node out/tests/test_harmony_state_mgmt.js --sourceDir tests/demo/harmony_state_mgmt --default tests/rules/minimal.rules.json --project tests/rules/harmony_state_mgmt.rules.json --k 1",
        "test:harmony-state:baseline": "node out/tests/test_harmony_state_mgmt.js --sourceDir tests/demo/harmony_state_mgmt --default tests/rules/minimal.rules.json --project tests/rules/harmony_state_mgmt.rules.json --k 1 --disableModeling",
        "test:harmony-e2e": "node out/tests/test_harmony_e2e.js --sourceDir tests/demo/harmony_e2e --default tests/rules/minimal.rules.json --project tests/rules/harmony_e2e.rules.json --k 1",
        "test:harmony-router-bridge": "node out/tests/test_harmony_router_bridge.js --sourceDir tests/demo/harmony_router_bridge --default tests/rules/minimal.rules.json --project tests/rules/harmony_router_bridge.rules.json --k 1",
        "test:harmony-router-crossfile": "node out/tests/test_harmony_router_bridge.js --sourceDir tests/demo/harmony_router_crossfile --default tests/rules/minimal.rules.json --project tests/rules/harmony_router_crossfile.rules.json --k 1",
        "test:entry-model": "node out/tests/test_entry_model_dummy_main.js",
        "test:harmony-bench": "node --max-old-space-size=4096 out/tests/test_harmony_bench.js",
        "test:harmony-bench:gate:c12-c14": "node --max-old-space-size=4096 out/tests/test_harmony_bench.js --manifest tests/benchmark/HarmonyBench/gates/c12_c14_gate.manifest.json --k 1 --outputDir tmp/harmony_bench/gates/c12_c14",
        "generate:harmony-metamorphic": "node out/tools/harmony_metamorphic_generator.js --manifest tests/benchmark/HarmonyBench/manifest.json --outputRoot tmp/harmony_bench_metamorphic/generated --groups A,B --categoryRegex \"^C[1-5]_\"",
        "test:harmony-bench:metamorphic:quick": "node --max-old-space-size=4096 out/tests/test_harmony_bench_metamorphic.js --manifest tests/benchmark/HarmonyBench/manifest.json --outputDir tmp/harmony_bench_metamorphic --docs docs/harmony_bench_metamorphic.md --k 1 --groups A,B --maxCasesPerCategory 1 --categoryRegex \"^C[1-5]_\"",
        "test:harmony-bench:metamorphic": "node --max-old-space-size=4096 out/tests/test_harmony_bench_metamorphic.js --manifest tests/benchmark/HarmonyBench/manifest.json --outputDir tmp/harmony_bench_metamorphic --docs docs/harmony_bench_metamorphic.md --k 1 --groups A,B --categoryRegex \"^C[1-5]_\"",
        "test:source-precision": "node out/tests/test_source_precision.js --sourceDir tests/demo/rule_precision_source --default tests/rules/minimal.rules.json --project tests/rules/source_precision.rules.json --k 1",
        "test:source-exact": "node out/tests/test_source_exact_match.js",
        "test:sink-precision": "node out/tests/test_sink_precision.js --sourceDir tests/demo/rule_precision_sink --default tests/rules/minimal.rules.json --project tests/rules/sink_precision.rules.json --k 1",
        "test:sink-exact": "node out/tests/test_sink_exact_match.js",
        "test:sanitizer-guard": "node out/tests/test_sanitizer_guard.js --sourceDir tests/demo/rule_precision_sanitizer --default tests/rules/minimal.rules.json --project tests/rules/sanitizer_guard.rules.json --k 1",
        "test:transfer-precision": "node out/tests/test_transfer_precision.js --sourceDir tests/demo/rule_precision_transfer --default tests/rules/minimal.rules.json --project tests/rules/transfer_precision.rules.json --k 1",
        "test:transfer-exact": "node out/tests/test_transfer_exact_match.js",
        "test:transfer-priority": "node out/tests/test_transfer_priority.js --sourceDir tests/demo/transfer_priority --default tests/rules/minimal.rules.json --project tests/rules/transfer_priority.rules.json --k 1",
        "test:transfer-tierc": "node out/tests/test_transfer_tier_c_guard.js",
        "test:transfer-ptr": "node out/tests/test_transfer_ptr_callee_resolution.js",
        "test:transfer-structural-perf": "node out/tests/test_transfer_structural_callee_perf.js",
        "test:transfer-overload": "node out/tests/test_transfer_overload_conflicts.js --sourceDir tests/demo/transfer_overload_conflicts --default tests/rules/minimal.rules.json --project tests/rules/transfer_overload_conflicts.rules.json --k 1",
        "test:transfer-rules": "node out/tests/test_transfer_rules.js --sourceDir tests/demo/rule_transfer --project tests/rules/transfer_only.rules.json --k 1",
        "test:transfer-cache-reuse": "node out/tests/test_transfer_cache_reuse.js --sourceDir tests/demo/rule_transfer_variants --default tests/rules/minimal.rules.json --project tests/rules/transfer_variants.rules.json --k 1 --maxCases 4",
        "test:analyze-incremental": "node out/tests/test_analyze_incremental.js",
        "test:analyze-parallel": "node out/tests/test_analyze_parallel_deterministic.js",
        "test:analyze-report-mode": "node out/tests/test_analyze_report_mode.js",
        "test:analyze-guidance": "node out/tests/test_analyze_guidance.js",
        "test:analyze-deprecated-flags": "node out/tests/test_analyze_deprecated_entry_flags.js",
        "test:no-candidate-project-pool": "node out/tests/test_no_candidate_project_candidate_pool.js",
        "test:analyze-single-command": "node out/tests/test_analyze_single_command.js",
        "test:phase66-detect-perf": "node out/tests/archive/test_phase66_detect_perf.js --rounds 5 --threshold 0.2 --k 1 --outputDir tmp/phase66 --tag round1",
        "test:analyze-perf-profile": "node out/tests/test_analyze_perf_profile.js --rounds 3 --threshold 0.3 --k 1 --maxEntries 12 --outputDir tmp/phase56 --tag round1",
        "test:analyze-perf-compare-arktan": "node out/tests/test_analyze_perf_compare_arktan.js --rounds 5 --k 1 --outputDir tmp/phase56 --arktanRoot ../Arktan --tag round1 --runStability",
        "test:transfer-benchmark": "node out/tests/test_transfer_perf_benchmark.js --rounds 5 --noiseRules 400 --threshold 0.3 --k 1 --outputDir tmp/phase54d/transfer_perf_benchmark",
        "test:transfer-compare-arktan": "node out/tests/test_transfer_compare_arktan.js --rounds 5 --k 1 --outputDir tmp/phase55 --arktanRoot ../Arktan --runStability",
        "test:senior-compare-arktan": "node out/tests/test_senior_compare_arktan.js --mode strict --rounds 1 --k 1 --outputDir tmp/senior_compare_arktan --arktanRoot ../Arktan --sourceRoot tests/demo/senior_full",
        "test:phase55-gap-list": "node out/tests/archive/test_phase55_gap_list.js --report tmp/phase55/compare_report.json --output tmp/phase55/gap_list.md",
        "test:project-rules-workflow": "node out/tests/test_project_rules_only_workflow.js",
        "verify:generalization": "npm run build && node out/tests/test_verify_generalization.js",
        "test:adaptive": "node out/tests/test_adaptive_context.js",
        "debug:phase35": "node out/tests/archive/test_phase35_debug.js",
        "analyze": "node out/cli/analyze.js",
        "generate:project-rules": "node out/cli/generate_project_rules.js",
        "analyze:demo": "node out/cli/analyze.js --repo tests/demo/complex_calls --sourceDir . --profile default --maxEntries 12 --outputDir tmp/analyze/demo_complex_calls",
        "test:rule-scaffold": "node out/tests/test_rule_scaffold_generation.js",
        "dump:invoke-signatures": "node out/cli/dump_invoke_signatures.js",
        "test:sdk-signature-probe": "npm run dump:invoke-signatures -- --repo tests/demo/sdk_signature_probe --sourceDir . --output tmp/sdk_signature_probe/signatures.json",
        "test:framework-probe-coverage": "npm run build && node out/tests/test_framework_probe_coverage.js",
        "verify:legacy-synthetic": "npm run build && npm run test:context && npm run test:full",
        "verify": "npm run build && npm run test:entry-model && npm run test:analyze-single-command && npm run test:analyze-guidance && npm run test:analyze-incremental && npm run test:analyze-deprecated-flags && npm run test:rule-scaffold",
        "verify:dev": "npm run verify && npm run test:smoke && npm run test:project-rules-workflow",
        "clean": "rimraf out",
        "llm:generate": "npx ts-node tools/llm_rule_generator.ts",
        "llm:generate:mock": "npx ts-node tools/llm_rule_generator.ts --mock"
    },
    "author": "",
    "license": "Apache-2.0",
    "devDependencies": {
        "@types/node": "^18.15.11",
        "@typescript-eslint/eslint-plugin": "^5.59.0",
        "@typescript-eslint/parser": "^5.59.0",
        "eslint": "^8.38.0",
        "jest": "^29.5.0",
        "rimraf": "^5.0.0",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.0.4",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "commander": "^10.0.0",
        "log4js": "^6.9.1",
        "openai": "^6.29.0",
        "pdf-parse": "^2.4.5"
    }
}
