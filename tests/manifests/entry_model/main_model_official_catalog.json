{
  "name": "main-model-official-catalog",
  "version": "1.0.0",
  "scope": "ArkTS/Harmony real entry situations",
  "purpose": "Source-of-truth catalog for entry coverage. Benchmark suites are only evidence against this catalog, not the catalog itself.",
  "sourceBasis": {
    "officialRoots": [
      {
        "id": "docs_center",
        "url": "https://developer.huawei.com/consumer/cn/doc/",
        "focus": "Official HarmonyOS documentation root and API/manual navigation."
      },
      {
        "id": "stage_model",
        "url": "https://developer.huawei.com/consumer/cn/arkui/arkui-stage/",
        "focus": "Stage model, UIAbility, ExtensionAbility, AbilityStage, WindowStage."
      },
      {
        "id": "arkui_portal",
        "url": "https://developer.huawei.com/consumer/cn/arkui/",
        "focus": "ArkUI state management, component events, navigation, declarative UI."
      }
    ],
    "localEvidence": [
      "arkanalyzer/node_modules/ohos-typescript/lib/*.d.ts",
      "tests/demo/sdk_signature_probe/taint_mock.ts",
      "tests/benchmark/HarmonyBench/manifest.json",
      "tests/demo/harmony_*",
      "tests/demo/harmony_framework_entry_probe"
    ]
  },
  "coveragePolicy": {
    "statusEnum": [
      "covered",
      "partial",
      "missing"
    ],
    "requiredCaseShapesPerFamily": [
      "positive",
      "negative",
      "boundary",
      "indirect_or_dynamic",
      "composition"
    ]
  },
  "categories": [
    {
      "id": "ability_stage_lifecycle",
      "title": "应用 / Stage / Window 生命周期",
      "families": [
        {
          "id": "uiability_lifecycle",
          "entrySituations": [
            "onCreate",
            "onDestroy",
            "onForeground",
            "onBackground",
            "onNewWant"
          ],
          "benchmarkStatus": "covered",
          "benchmarkSuites": [
            "harmony_lifecycle",
            "harmony_multi_ability_chain"
          ],
          "missingVariants": []
        },
        {
          "id": "abilitystage_lifecycle",
          "entrySituations": [
            "AbilityStage.onCreate"
          ],
          "benchmarkStatus": "covered",
          "benchmarkSuites": [
            "harmony_lifecycle",
            "harmony_stage_window_variants"
          ],
          "missingVariants": []
        },
        {
          "id": "windowstage_lifecycle_and_callbacks",
          "entrySituations": [
            "onWindowStageCreate",
            "onWindowStageDestroy",
            "WindowStage.loadContent(callback)"
          ],
          "benchmarkStatus": "covered",
          "benchmarkSuites": [
            "harmony_lifecycle",
            "harmony_framework_system_callbacks",
            "harmony_system_callback_variants",
            "harmony_stage_window_variants"
          ],
          "missingVariants": []
        }
      ]
    },
