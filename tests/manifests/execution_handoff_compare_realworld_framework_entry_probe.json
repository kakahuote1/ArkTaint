      "expected": true,
      "layer": "natural_sample_reserved",
      "twinGroup": "realworld_onclick_direct",
      "semanticFamily": "framework_entry_realworld",
      "variantId": "onclick_direct",
      "polarity": "positive",
      "semanticFlip": "framework_entry_payload_consumed",
      "note": "Direct framework onClick callback in a realistic build method.",
      "factors": {
