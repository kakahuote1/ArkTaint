{
  "version": 1,
  "name": "execution_handoff_compare_realworld_framework_entry_probe",
  "sourceDir": "tests/demo/harmony_framework_entry_probe",
  "purpose": "Small real-world-style slice compare for Harmony framework entry variants under the same rule/runtime harness.",
  "globalFactorUniverse": {
    "carrier": ["direct_callable", "returned_callable", "field_callable", "slot_callable"],
    "trigger": ["call", "event", "settle_fulfilled", "settle_rejected", "settle_any"],
    "payload": ["none", "param0", "param1", "multi"],
    "capture": ["none", "capture_in", "capture_out", "capture_in_out"],
    "resume": ["none", "promise_chain", "await_site"],
    "relayDepth": [0, 1, 2],
    "bindingSite": ["local", "samefile_helper", "crossfile_helper", "field", "slot"],
    "deferred": [true, false]
  },
  "activeCompareScope": {
    "name": "realworld_framework_entry_probe",
    "outputTag": "realworld_framework_entry_probe",
    "activeLayers": ["natural_sample_reserved"],
    "rationale": [
      "Use a few framework-style demo slices instead of more synthetic mechanism rows.",
      "Keep the runtime fixed across paper_like, baseline, and contract_active, including the same project rule set.",
      "Do not use these slices to tune the algorithm; they only provide external-style evidence after the theory and controlled compares are frozen."
    ],
    "fixedFactors": {
      "trigger": ["event"],
      "resume": ["none"]
    },
    "deferredFocus": ["event"],
    "controlRows": [],
    "excludedForNow": [
      "Immediate field/slot callable invoke remains a shared common gap and is not part of this real-world deferred-handoff slice.",
      "This manifest is a natural-sample slice, not a twin-based factor-matrix benchmark."
    ]
  },
  "twinRules": [
    "Natural sample slices do not need to be positive/negative twins.",
    "Each slice should still have an explicit expected label and factor annotation."
  ],
  "runtime": {
    "seedMode": "source_rules",
    "defaultRulePath": "tests/rules/minimal.rules.json",
    "projectRulePath": "tests/rules/harmony_framework_entry_probe.rules.json",
    "includeBuiltinSemanticPacks": false,
    "includeBuiltinEnginePlugins": false
  },
  "cases": [
    {
