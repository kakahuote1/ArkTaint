{
  "schemaVersion": "1.1",
  "meta": {
    "name": "harmony_rdb",
    "description": "C13 relational store benchmark rules (gate-ready minimal semantics)",
    "updatedAt": "2026-02-22"
  },
  "sources": [
    {
      "id": "source.harmony_rdb.entry_param",
      "profile": "entry_param",
      "match": {
        "kind": "local_name_regex",
        "value": "^taint_src$"
      }
    }
  ],
  "sinks": [
    {
      "id": "sink.harmony_rdb.mock_sink",
      "profile": "signature",
      "sinkTargetRef": {
        "endpoint": "arg0"
      },
      "match": {
        "kind": "method_name_equals",
        "value": "Sink"
      }
    }
  ],
  "sanitizers": [],
  "transfers": [
    {
      "id": "transfer.harmony_rdb.insert_row_to_store",
      "description": "Model insert(table, row): row taints db instance.",
      "match": {
        "kind": "method_name_equals",
        "value": "insert"
      },
      "invokeKind": "instance",
      "argCount": 2,
      "typeHint": "RdbStore",
      "from": "arg1",
      "to": "base"
    },
    {
      "id": "transfer.harmony_rdb.query_store_to_result",
      "description": "Model query(sql): tainted db instance taints query result.",
      "match": {
        "kind": "method_name_equals",
        "value": "query"
      },
      "invokeKind": "instance",
      "argCount": 1,
      "typeHint": "RdbStore",
      "from": "base",
      "to": "result"
    }
  ]
}
