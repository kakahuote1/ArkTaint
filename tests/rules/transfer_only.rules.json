{
    "schemaVersion": "2.0",
    "meta": {
        "name": "transfer-only-rule-pack",
        "description": "Rules used by transfer execution tests",
        "updatedAt": "2026-02-14"
    },
    "sources": [
        {
            "id": "source.test.entry_param.taint_src",
            "match": {
                "kind": "local_name_regex",
                "value": "^taint_src$"
            },
            "sourceKind": "entry_param",
            "target": "arg0"
        }
    ],
    "sinks": [
        {
            "id": "sink.test.method.Sink",
            "match": {
                "kind": "method_name_equals",
                "value": "Sink"
            },
            "target": "arg0"
        }
    ],
    "transfers": [
        {
            "id": "transfer.test.putData.arg0_to_base",
            "match": {
                "kind": "method_name_equals",
                "value": "putData",
                "invokeKind": "instance",
                "argCount": 1
            },
            "from": "arg0",
            "to": "base"
        },
        {
            "id": "transfer.test.get.base_to_result",
            "match": {
                "kind": "method_name_equals",
                "value": "get",
                "invokeKind": "instance",
                "argCount": 0
            },
            "from": "base",
            "to": "result"
        },
        {
            "id": "transfer.test.putPair.arg1_to_base",
            "match": {
                "kind": "method_name_equals",
                "value": "putPair",
                "invokeKind": "instance",
                "argCount": 2
            },
            "from": "arg1",
            "to": "base"
        },
        {
            "id": "transfer.test.bind.arg0_to_base",
            "match": {
                "kind": "method_name_equals",
                "value": "bind",
                "invokeKind": "instance",
                "argCount": 1
            },
            "from": "arg0",
            "to": "base"
        },
        {
            "id": "transfer.test.paint.base_to_arg0",
            "match": {
                "kind": "method_name_equals",
                "value": "paint",
                "invokeKind": "instance",
                "argCount": 1
            },
            "from": "base",
            "to": "arg0"
        },
        {
            "id": "transfer.test.blend.arg1_to_result",
            "match": {
                "kind": "method_name_equals",
                "value": "blend",
                "invokeKind": "static",
                "argCount": 2
            },
            "from": "arg1",
            "to": "result"
        },
        {
            "id": "transfer.test.project.result_to_arg0",
            "match": {
                "kind": "method_name_equals",
                "value": "project",
                "invokeKind": "static",
                "argCount": 1
            },
            "from": "result",
            "to": "arg0"
        }
    ]
}
