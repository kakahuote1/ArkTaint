{
    "schemaVersion": "2.0",
    "meta": {
        "name": "harmony-appstorage-v1-rules",
        "description": "Source/Sink rules for Phase 7.2 AppStorage modeling tests",
        "updatedAt": "2026-02-22"
    },
    "sources": [
        {
            "id": "source.harmony.appstorage.mock_source",
            "match": {
                "kind": "local_name_regex",
                "value": "^taint_src$"
            },
            "sourceKind": "entry_param",
            "target": "arg0"
        }
    ],
    "sinks": [
        {
            "id": "sink.harmony.appstorage.mock_sink",
            "match": {
                "kind": "method_name_equals",
                "value": "Sink"
            },
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "transfers": []
}
