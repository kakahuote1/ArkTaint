{
    "schemaVersion": "2.0",
    "meta": {
        "name": "sink-precision-rule-pack",
        "description": "Rules used to validate sinkTarget precise endpoint detection",
        "updatedAt": "2026-02-15"
    },
    "sources": [
        {
            "id": "source.test.entry_param.taint_src",
            "match": {
                "kind": "local_name_regex",
                "value": "^taint_src$"
            },
            "sourceKind": "entry_param",
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "sinks": [
        {
            "id": "sink.precision.arg0",
            "match": {
                "kind": "method_name_equals",
                "value": "SinkArg0"
            },
            "severity": "medium",
            "target": {
                "endpoint": "arg0"
            }
        },
        {
            "id": "sink.precision.arg1",
            "match": {
                "kind": "method_name_equals",
                "value": "SinkArg1"
            },
            "severity": "medium",
            "target": {
                "endpoint": "arg1"
            }
        },
        {
            "id": "sink.precision.field.secret",
            "match": {
                "kind": "method_name_equals",
                "value": "SinkField"
            },
            "category": "field_path",
            "severity": "high",
            "target": {
                "endpoint": "arg0",
                "path": [
                    "secret"
                ]
            }
        },
        {
            "id": "sink.precision.invoke_kind.instance",
            "match": {
                "kind": "method_name_equals",
                "value": "SinkInvokeKind",
                "invokeKind": "instance"
            },
            "category": "invoke_kind",
            "severity": "medium",
            "target": {
                "endpoint": "arg0"
            }
        },
        {
            "id": "sink.precision.arg_count.two",
            "match": {
                "kind": "method_name_equals",
                "value": "SinkArgCount",
                "argCount": 2
            },
            "category": "arg_count",
            "severity": "medium",
            "target": {
                "endpoint": "arg0"
            }
        },
        {
            "id": "sink.precision.type_hint.target",
            "match": {
                "kind": "method_name_equals",
                "value": "SinkTypeHint",
                "invokeKind": "instance",
                "typeHint": "TypeHintHostTarget"
            },
            "category": "type_hint",
            "severity": "medium",
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "transfers": []
}
