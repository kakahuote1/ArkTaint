{
    "schemaVersion": "2.0",
    "meta": {
        "name": "harmony_http",
        "description": "C14 http benchmark rules (gate-ready minimal semantics)",
        "updatedAt": "2026-02-22"
    },
    "sources": [
        {
            "id": "source.harmony_http.entry_param",
            "match": {
                "kind": "local_name_regex",
                "value": "^taint_src$"
            },
            "sourceKind": "entry_param",
            "target": "arg0"
        },
        {
            "id": "source.harmony_http.request_async_callback_arg0",
            "match": {
                "kind": "method_name_equals",
                "value": "requestAsync"
            },
            "sourceKind": "callback_param",
            "target": {
                "endpoint": "arg0"
            },
            "callbackArgIndexes": [
                1
            ]
        }
    ],
    "sinks": [
        {
            "id": "sink.harmony_http.mock_sink",
            "match": {
                "kind": "method_name_equals",
                "value": "Sink"
            },
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "transfers": [
        {
            "id": "transfer.harmony_http.request_arg_to_result",
            "description": "Model request(url, data): request payload taints response object in benchmark.",
            "match": {
                "kind": "method_name_equals",
                "value": "request",
                "invokeKind": "instance",
                "argCount": 2,
                "typeHint": "Http"
            },
            "from": "arg1",
            "to": "result"
        }
    ]
}
