{
    "schemaVersion": "2.0",
    "meta": {
        "name": "harmony-router-crossfile-rules",
        "description": "Rules for cross-file router bridge validation in phase 7.8.4.",
        "updatedAt": "2026-02-28"
    },
    "sources": [
        {
            "id": "source.router_crossfile.entry_param",
            "match": {
                "kind": "local_name_regex",
                "value": "^taint_src$"
            },
            "sourceKind": "entry_param",
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "sinks": [
        {
            "id": "sink.router_crossfile.mock_sink",
            "match": {
                "kind": "method_name_equals",
                "value": "Sink"
            },
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "transfers": []
}
