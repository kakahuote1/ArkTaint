{
    "schemaVersion": "2.0",
    "meta": {
        "name": "layer-llm",
        "updatedAt": "2026-02-14"
    },
    "sources": [
        {
            "id": "source.layer.same",
            "match": {
                "kind": "local_name_regex",
                "value": "llm_src"
            },
            "sourceKind": "seed_local_name",
            "target": "result"
        },
        {
            "id": "source.layer.llm_only",
            "match": {
                "kind": "local_name_regex",
                "value": "llm_only"
            },
            "sourceKind": "seed_local_name",
            "target": "result"
        }
    ],
    "sinks": [
        {
            "id": "sink.layer.same",
            "match": {
                "kind": "signature_contains",
                "value": "llm_sink"
            }
        },
        {
            "id": "sink.layer.llm_only",
            "match": {
                "kind": "signature_contains",
                "value": "llm_sink_only"
            }
        }
    ],
    "transfers": [
        {
            "id": "transfer.layer.same",
            "match": {
                "kind": "method_name_equals",
                "value": "transferSame"
            },
            "from": "result",
            "to": "arg0"
        },
        {
            "id": "transfer.layer.llm_only",
            "match": {
                "kind": "method_name_equals",
                "value": "transferLlmOnly"
            },
            "from": "arg1",
            "to": "result"
        }
    ]
}
