{
    "schemaVersion": "2.0",
    "meta": {
        "name": "layer-framework",
        "updatedAt": "2026-02-14"
    },
    "sources": [
        {
            "id": "source.layer.same",
            "match": {
                "kind": "local_name_regex",
                "value": "framework_src"
            },
            "sourceKind": "seed_local_name",
            "target": "result"
        },
        {
            "id": "source.layer.framework_only",
            "match": {
                "kind": "local_name_regex",
                "value": "framework_only"
            },
            "sourceKind": "seed_local_name",
            "target": "result"
        }
    ],
    "sinks": [
        {
            "id": "sink.layer.same",
            "match": {
                "kind": "signature_contains",
                "value": "framework_sink"
            }
        },
        {
            "id": "sink.layer.framework_only",
            "match": {
                "kind": "signature_contains",
                "value": "framework_sink_only"
            }
        }
    ],
    "transfers": [
        {
            "id": "transfer.layer.same",
            "match": {
                "kind": "method_name_equals",
                "value": "transferSame"
            },
            "from": "arg1",
            "to": "base"
        },
        {
            "id": "transfer.layer.framework_only",
            "match": {
                "kind": "method_name_equals",
                "value": "transferFrameworkOnly"
            },
            "from": "base",
            "to": "arg0"
        }
    ]
}
