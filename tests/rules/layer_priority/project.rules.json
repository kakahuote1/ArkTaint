{
    "schemaVersion": "2.0",
    "meta": {
        "name": "layer-project",
        "updatedAt": "2026-02-14"
    },
    "sources": [
        {
            "id": "source.layer.same",
            "match": {
                "kind": "local_name_regex",
                "value": "project_src"
            },
            "sourceKind": "seed_local_name",
            "target": "result"
        },
        {
            "id": "source.layer.project_only",
            "match": {
                "kind": "local_name_regex",
                "value": "project_only"
            },
            "sourceKind": "seed_local_name",
            "target": "result"
        }
    ],
    "sinks": [
        {
            "id": "sink.layer.same",
            "match": {
                "kind": "signature_contains",
                "value": "project_sink"
            }
        },
        {
            "id": "sink.layer.project_only",
            "match": {
                "kind": "signature_contains",
                "value": "project_sink_only"
            }
        }
    ],
    "transfers": [
        {
            "id": "transfer.layer.same",
            "match": {
                "kind": "method_name_equals",
                "value": "transferSame"
            },
            "from": "base",
            "to": "result"
        },
        {
            "id": "transfer.layer.project_only",
            "match": {
                "kind": "method_name_equals",
                "value": "transferProjectOnly"
            },
            "from": "arg0",
            "to": "arg1"
        }
    ]
}
