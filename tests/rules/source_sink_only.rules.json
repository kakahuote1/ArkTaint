{
    "schemaVersion": "2.0",
    "meta": {
        "name": "source-sink-only-rule-pack",
        "description": "Rule pack for source/sink core execution test",
        "updatedAt": "2026-02-14"
    },
    "sources": [
        {
            "id": "source.test.entry_param.taint_src",
            "match": {
                "kind": "local_name_regex",
                "value": "^taint_src$"
            },
            "sourceKind": "entry_param",
            "target": "arg0"
        }
    ],
    "sinks": [
        {
            "id": "sink.test.method_name.Sink",
            "match": {
                "kind": "method_name_equals",
                "value": "Sink"
            }
        }
    ],
    "transfers": []
}
