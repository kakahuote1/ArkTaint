{
    "schemaVersion": "2.0",
    "meta": {
        "name": "transfer-overload-conflicts-rule-pack",
        "description": "Rules used to validate overload/same-name transfer conflict isolation",
        "updatedAt": "2026-02-17"
    },
    "sources": [
        {
            "id": "source.transfer_overload.entry_param.taint_src",
            "match": {
                "kind": "local_name_regex",
                "value": "^taint_src$"
            },
            "sourceKind": "entry_param",
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "sinks": [
        {
            "id": "sink.transfer_overload.arg0",
            "match": {
                "kind": "method_name_equals",
                "value": "Sink"
            },
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "transfers": [
        {
            "id": "transfer.overload.instance.allowed.arg0_to_result",
            "match": {
                "kind": "declaring_class_equals",
                "value": "ConflictAllowed",
                "invokeKind": "instance"
            },
            "from": "arg0",
            "to": "result"
        },
        {
            "id": "transfer.overload.static.allowed.arg0_to_result",
            "match": {
                "kind": "declaring_class_equals",
                "value": "ConflictStaticAllowed",
                "invokeKind": "static"
            },
            "from": "arg0",
            "to": "result"
        },
        {
            "id": "transfer.overload.arity.two_args.arg1_to_result",
            "match": {
                "kind": "method_name_equals",
                "value": "BridgeArity",
                "invokeKind": "static",
                "argCount": 2
            },
            "from": "arg1",
            "to": "result"
        }
    ]
}
