{
    "schemaVersion": "2.0",
    "meta": {
        "name": "transfer-precision-rule-pack",
        "description": "Rules used to validate transfer precise execution",
        "updatedAt": "2026-02-17"
    },
    "sources": [
        {
            "id": "source.transfer_precision.entry_param.taint_src",
            "match": {
                "kind": "local_name_regex",
                "value": "^taint_src$"
            },
            "sourceKind": "entry_param",
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "sinks": [
        {
            "id": "sink.transfer_precision.arg0",
            "match": {
                "kind": "method_name_equals",
                "value": "Sink"
            },
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "transfers": [
        {
            "id": "transfer.precision.map.set.arg1_to_base_slot",
            "match": {
                "kind": "signature_contains",
                "value": "Map.set",
                "invokeKind": "instance",
                "argCount": 2
            },
            "from": "arg1",
            "to": {
                "endpoint": "base",
                "pathFrom": "arg0",
                "slotKind": "map"
            }
        },
        {
            "id": "transfer.precision.map.get.base_slot_to_result",
            "match": {
                "kind": "signature_contains",
                "value": "Map.get",
                "invokeKind": "instance",
                "argCount": 1
            },
            "from": {
                "endpoint": "base",
                "pathFrom": "arg0",
                "slotKind": "map"
            },
            "to": "result"
        },
        {
            "id": "transfer.precision.invoke_kind.instance_arg0_to_result",
            "match": {
                "kind": "method_name_equals",
                "value": "BridgeInvokeKind",
                "invokeKind": "instance"
            },
            "from": "arg0",
            "to": "result"
        },
        {
            "id": "transfer.precision.arg_count.two_arg1_to_result",
            "match": {
                "kind": "method_name_equals",
                "value": "BridgeArgCount",
                "argCount": 2
            },
            "from": "arg1",
            "to": "result"
        },
        {
            "id": "transfer.precision.type_hint.target_arg0_to_result",
            "match": {
                "kind": "method_name_equals",
                "value": "BridgeTypeHint",
                "invokeKind": "instance",
                "typeHint": "TransferTypeHostTarget"
            },
            "from": "arg0",
            "to": "result"
        },
        {
            "id": "transfer.precision.scope.allowed_class_arg0_to_result",
            "match": {
                "kind": "method_name_equals",
                "value": "BridgeScope",
                "invokeKind": "instance"
            },
            "scope": {
                "className": {
                    "mode": "contains",
                    "value": "ScopeHostAllowed"
                }
            },
            "from": "arg0",
            "to": "result"
        },
        {
            "id": "transfer.precision.compose.pipe.arg0_to_base",
            "match": {
                "kind": "method_name_equals",
                "value": "Pipe",
                "invokeKind": "instance"
            },
            "from": "arg0",
            "to": "base"
        },
        {
            "id": "transfer.precision.compose.pipe.base_to_result",
            "match": {
                "kind": "method_name_equals",
                "value": "Pipe",
                "invokeKind": "instance"
            },
            "from": "base",
            "to": "result"
        }
    ]
}
