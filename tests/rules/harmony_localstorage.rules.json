{
    "schemaVersion": "2.0",
    "meta": {
        "name": "harmony-localstorage-v1-rules",
        "description": "LocalStorage and LocalStorage decorators modeling tests",
        "updatedAt": "2026-03-01"
    },
    "sources": [
        {
            "id": "source.harmony.localstorage.entry_param",
            "match": {
                "kind": "local_name_regex",
                "value": "^taint_src$"
            },
            "sourceKind": "entry_param",
            "target": "arg0"
        }
    ],
    "sinks": [
        {
            "id": "sink.harmony.localstorage.mock_sink",
            "match": {
                "kind": "method_name_equals",
                "value": "Sink"
            },
            "target": {
                "endpoint": "arg0"
            }
        }
    ],
    "transfers": []
}
