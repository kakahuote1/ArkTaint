{
  "version": 1,
  "name": "execution_handoff_compare_async_matrix",
  "sourceDir": "tests/adhoc/execution_handoff_compare_async",
  "purpose": "Fair comparison for Promise/await payload-resume handoff behavior under fixed source, sink, and builtin-model settings.",
  "globalFactorUniverse": {
    "carrier": ["direct_callable", "returned_callable", "field_callable", "slot_callable"],
    "trigger": ["call", "event", "settle_fulfilled", "settle_rejected", "settle_any"],
    "payload": ["none", "param0", "param1", "multi"],
    "capture": ["none", "capture_in", "capture_out", "capture_in_out"],
    "resume": ["none", "promise_chain", "await_site"],
    "relayDepth": [0, 1, 2],
    "bindingSite": ["local", "samefile_helper", "crossfile_helper", "field", "slot"],
    "deferred": [true, false]
  },
  "activeCompareScope": {
    "name": "async_payload_resume_core",
    "outputTag": "async_payload_resume_core",
    "activeLayers": ["mechanism_benchmark", "boundary_control"],
    "rationale": [
      "Compare only the payload/resume dimension of ordinary Promise/await handoff under fixed direct-callable, local binding assumptions.",
      "Keep source shape, sink shape, builtin semantic packs, and engine plugins fixed to avoid introducing unrelated modeling variables.",
      "Use positive/negative twins where only taint consumption or value return differs."
    ],
    "fixedFactors": {
      "carrier": ["direct_callable"],
      "bindingSite": ["local"],
      "relayDepth": ["0"],
      "trigger": ["settle_fulfilled", "settle_rejected", "settle_any", "call"]
    },
    "deferredFocus": ["settle_fulfilled", "settle_rejected", "settle_any"],
    "controlRows": ["call"],
    "excludedForNow": [
      "Returned/field/slot carriers are excluded from this layer because this layer isolates payload-resume semantics only.",
      "Event registration is excluded because it is already covered by the event handoff compare layer."
    ]
  },
  "twinRules": [
    "Each twin group must contain exactly one positive case and one negative case.",
    "Twin cases must share the same semantic factors; only taint consumption or returned value use may differ.",
    "Boundary-control rows are allowed, but must still satisfy the twin rule."
  ],
  "cases": [
    {
      "caseName": "promise_then_chain_payload_001_T",
      "expected": true,
      "layer": "mechanism_benchmark",
      "twinGroup": "promise_then_chain_payload",
      "polarity": "positive",
      "semanticFlip": "returned_value_consumed_at_sink",
      "note": "Fulfilled continuation propagates payload through promise-chain resume.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "settle_fulfilled",
        "payload": "param0",
        "capture": "none",
        "resume": "promise_chain",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": true
      }
    },
    {
      "caseName": "promise_then_chain_payload_002_F",
      "expected": false,
      "layer": "mechanism_benchmark",
      "twinGroup": "promise_then_chain_payload",
      "polarity": "negative",
      "semanticFlip": "returned_value_consumed_at_sink",
      "note": "Fulfilled continuation returns safe value before promise-chain sink.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "settle_fulfilled",
        "payload": "param0",
        "capture": "none",
        "resume": "promise_chain",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": true
      }
    },
    {
      "caseName": "promise_catch_await_payload_003_T",
      "expected": true,
      "layer": "mechanism_benchmark",
      "twinGroup": "promise_catch_await_payload",
      "polarity": "positive",
      "semanticFlip": "returned_value_consumed_at_sink",
      "note": "Rejected continuation propagates payload to await resume site.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "settle_rejected",
        "payload": "param0",
        "capture": "none",
        "resume": "await_site",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": true
      }
    },
    {
      "caseName": "promise_catch_await_payload_004_F",
      "expected": false,
      "layer": "mechanism_benchmark",
      "twinGroup": "promise_catch_await_payload",
      "polarity": "negative",
      "semanticFlip": "returned_value_consumed_at_sink",
      "note": "Rejected continuation returns safe value before await sink.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "settle_rejected",
        "payload": "param0",
        "capture": "none",
        "resume": "await_site",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": true
      }
    },
    {
      "caseName": "promise_finally_capture_005_T",
      "expected": true,
      "layer": "mechanism_benchmark",
      "twinGroup": "promise_finally_capture",
      "polarity": "positive",
      "semanticFlip": "capture_consumed_at_sink",
      "note": "Finally continuation has no payload and consumes captured source.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "settle_any",
        "payload": "none",
        "capture": "capture_in",
        "resume": "none",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": true
      }
    },
    {
      "caseName": "promise_finally_capture_006_F",
      "expected": false,
      "layer": "mechanism_benchmark",
      "twinGroup": "promise_finally_capture",
      "polarity": "negative",
      "semanticFlip": "capture_consumed_at_sink",
      "note": "Finally continuation preserves shape but does not consume captured source at sink.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "settle_any",
        "payload": "none",
        "capture": "capture_in",
        "resume": "none",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": true
      }
    },
    {
      "caseName": "promise_executor_control_007_T",
      "expected": true,
      "layer": "boundary_control",
      "twinGroup": "promise_executor_control",
      "polarity": "positive",
      "semanticFlip": "taint_consumed_at_sink",
      "note": "Promise executor executes immediately and should remain a non-deferred control row.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "call",
        "payload": "none",
        "capture": "capture_in",
        "resume": "none",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": false
      }
    },
    {
      "caseName": "promise_executor_control_008_F",
      "expected": false,
      "layer": "boundary_control",
      "twinGroup": "promise_executor_control",
      "polarity": "negative",
      "semanticFlip": "taint_consumed_at_sink",
      "note": "Immediate executor twin without consuming source at sink.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "call",
        "payload": "none",
        "capture": "capture_in",
        "resume": "none",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": false
      }
    }
  ]
}
