{
  "version": 1,
  "name": "execution_handoff_compare_matrix",
  "sourceDir": "tests/adhoc/execution_handoff_compare",
  "purpose": "Fair comparison for execution handoff ability by semantic factor coverage instead of algorithm-advantaged case picking.",
  "globalFactorUniverse": {
    "carrier": ["direct_callable", "returned_callable", "field_callable", "slot_callable"],
    "trigger": ["call", "event", "settle_fulfilled", "settle_rejected", "settle_any"],
    "payload": ["none", "param0", "param1", "multi"],
    "capture": ["none", "capture_in", "capture_out", "capture_in_out"],
    "resume": ["none", "promise_chain", "await_site"],
    "relayDepth": [0, 1, 2],
    "bindingSite": ["local", "samefile_helper", "crossfile_helper", "field", "slot"],
    "deferred": [true, false]
  },
  "activeCompareScope": {
    "name": "event_handoff_delta_core",
    "outputTag": "event_handoff_delta_core",
    "activeLayers": ["mechanism_benchmark", "boundary_control"],
    "rationale": [
      "Only compare the part that the new contract layer currently changes directly: event/deferred callback handoff inference and edge emission.",
      "Keep payload, resume, builtin semantic packs, engine plugins, source shape, and sink shape fixed to avoid extra variables.",
      "Use positive/negative twins so each semantic row differs only by whether taint is consumed at the sink."
    ],
    "fixedFactors": {
      "payload": ["none"],
      "capture": ["capture_in"],
      "resume": ["none"],
      "carrier": ["direct_callable", "returned_callable"],
      "trigger": ["event", "call"]
    },
    "deferredFocus": ["event"],
    "controlRows": ["call"],
    "excludedForNow": [
      "Promise/await rows are validated in theory tests but are excluded from this head-to-head compare layer because ordinary async propagation remains an additional active variable.",
      "field/slot callable rows are reserved for a later compare layer after the current event-handoff delta is stabilized."
    ]
  },
  "twinRules": [
    "Each twin group must contain exactly one positive case and one negative case.",
    "Twin cases must share the same semantic factors; only taint consumption at the sink may differ.",
    "Boundary-control rows are allowed, but must still satisfy the twin rule."
  ],
  "cases": [
    {
      "caseName": "event_direct_capture_001_T",
      "expected": true,
      "layer": "mechanism_benchmark",
      "twinGroup": "event_direct_local",
      "polarity": "positive",
      "semanticFlip": "taint_consumed_at_sink",
      "note": "Direct local event registration with captured source.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "event",
        "payload": "none",
        "capture": "capture_in",
        "resume": "none",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": true
      }
    },
    {
      "caseName": "event_direct_safe_002_F",
      "expected": false,
      "layer": "mechanism_benchmark",
      "twinGroup": "event_direct_local",
      "polarity": "negative",
      "semanticFlip": "taint_consumed_at_sink",
      "note": "Direct local event registration without consuming captured source at sink.",
      "factors": {
        "carrier": "direct_callable",
        "trigger": "event",
        "payload": "none",
        "capture": "capture_in",
        "resume": "none",
        "relayDepth": 0,
        "bindingSite": "local",
        "deferred": true
      }
    },
    {
