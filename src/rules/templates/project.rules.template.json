{
  "schemaVersion": "1.1",
  "meta": {
    "name": "arktaint-project-rule-template",
    "description": "Project rule template. Keep disabled=false only after manual confirmation. Common mistakes: wrong endpoint(arg index), overly broad match, missing scope.",
    "updatedAt": "2026-02-17"
  },
  "sources": [
    {
      "id": "source.template.entry_param.arg0",
      "enabled": false,
      "description": "[模板] 入口参数作为 source。确认方法名与参数位点后再启用。",
      "tags": [
        "template",
        "source",
        "entry_param"
      ],
      "profile": "entry_param",
      "kind": "entry_param",
      "match": {
        "kind": "method_name_equals",
        "value": "onSubmit"
      },
      "target": "arg0",
      "targetRef": {
        "endpoint": "arg0"
      }
    }
  ],
  "sinks": [
    {
      "id": "sink.template.network.request.arg0",
      "enabled": false,
      "description": "[模板] 网络请求发送点。确认签名与 sinkTarget 后再启用。",
      "tags": [
        "template",
        "sink"
      ],
      "profile": "signature",
      "severity": "medium",
      "category": "network",
      "match": {
        "kind": "signature_equals",
        "value": "<@entry/src/main/ets/pages/Index.ets: Network.send(any)>"
      },
      "invokeKind": "static",
      "argCount": 1,
      "sinkTarget": "arg0",
      "sinkTargetRef": {
        "endpoint": "arg0"
      }
    }
  ],
  "transfers": [
    {
      "id": "transfer.template.wrapper.arg0_to_result",
      "enabled": false,
      "description": "[模板] 包装器透传规则。常见错误：from/to 端点写反、argCount 不匹配、pathFrom 缺少 slotKind。",
      "tags": [
        "template",
        "transfer"
      ],
      "match": {
        "kind": "signature_equals",
        "value": "<@entry/src/main/ets/pages/Index.ets: Wrapper.wrap(any)>"
      },
      "invokeKind": "static",
      "argCount": 1,
      "from": "arg0",
      "to": "result",
      "fromRef": {
        "endpoint": "arg0"
      },
      "toRef": {
        "endpoint": "result"
      }
    },
    {
      "id": "transfer.template.map.set.arg1_to_base_slot",
      "enabled": false,
      "description": "[模板] 动态键容器规则。把 arg1 的污点写入 base[key] 槽位，供后续 get(key) 精确读取。",
      "tags": [
        "template",
        "transfer",
        "pathFrom"
      ],
      "match": {
        "kind": "signature_contains",
        "value": "Map.set"
      },
      "invokeKind": "instance",
      "argCount": 2,
      "from": "arg1",
      "to": "base",
      "toRef": {
        "endpoint": "base",
        "pathFrom": "arg0",
        "slotKind": "map"
      }
    },
    {
      "id": "transfer.template.map.get.base_slot_to_result",
      "enabled": false,
      "description": "[模板] 动态键容器读取规则。把 base[key] 槽位的污点路由到 result。",
      "tags": [
        "template",
        "transfer",
        "pathFrom"
      ],
      "match": {
        "kind": "signature_contains",
        "value": "Map.get"
      },
      "invokeKind": "instance",
      "argCount": 1,
      "from": "base",
      "to": "result",
      "fromRef": {
        "endpoint": "base",
        "pathFrom": "arg0",
        "slotKind": "map"
      }
    }
  ]
}
