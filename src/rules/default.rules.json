    "transfers": [
        {
            "id": "transfer.map.set.value_to_base_slot",
            "description": "map.set(key, value): value taints the precise map slot selected by key.",
            "match": {
                "kind": "signature_contains",
                "value": "Map.set",
                "invokeKind": "instance",
                "argCount": 2
            },
            "from": "arg1",
            "to": {
                "endpoint": "base",
                "pathFrom": "arg0",
                "slotKind": "map"
            }
        },
        {
            "id": "transfer.map.set.key_to_base_keyslot",
            "description": "map.set(key, value): key taints the precise map-key slot selected by key.",
