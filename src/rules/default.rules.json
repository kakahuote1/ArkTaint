        {
            "id": "transfer.promise.then.base_to_arg0",
            "description": "promise.then(callback): promise value flows to callback first arg",
            "match": {
                "kind": "signature_contains",
                "value": "Promise.then"
            },
            "from": "base",
            "to": "arg0"
        },
        {
            "id": "transfer.promise.resolve.arg0_to_result",
            "description": "Promise.resolve(x): resolved promise carries taint from x.",
            "match": {
                "kind": "method_name_equals",
                "value": "resolve",
                "invokeKind": "static",
                "argCount": 1,
                "typeHint": "promise"
            },
            "from": "arg0",
            "to": "result"
        },
        {
            "id": "transfer.promise.reject.arg0_to_result",
            "description": "Promise.reject(x): rejected promise carries taint from x.",
            "match": {
                "kind": "method_name_equals",
                "value": "reject",
                "invokeKind": "static",
                "argCount": 1,
                "typeHint": "promise"
            },
            "from": "arg0",
            "to": "result"
        },
        {
            "id": "transfer.promise.catch.base_to_arg0",
            "description": "promise.catch(callback): rejection value flows to callback first arg.",
            "match": {
                "kind": "signature_contains",
                "value": "Promise.catch"
            },
            "from": "base",
            "to": "arg0"
        },
        {
            "id": "transfer.promise.finally.base_to_result",
            "description": "promise.finally(callback): original value transparently passes through.",
            "match": {
                "kind": "signature_contains",
                "value": "Promise.finally"
            },
            "from": "base",
            "to": "result"
        },
        {
            "id": "transfer.reflect.get.arg0_to_result",
            "description": "Reflect.get(target, key): target object field value flows to result.",
            "match": {
                "kind": "method_name_equals",
                "value": "get",
                "invokeKind": "static",
                "argCount": 2,
                "typeHint": "reflect"
            },
            "from": "arg0",
            "to": "result"
