      "id": "source.harmony.distributedkv.get.result",
      "enabled": true,
      "description": "Distributed KV get() return value as source.",
      "tags": [
        "harmony",
        "t2",
        "t5"
      ],
      "match": {
        "kind": "method_name_equals",
        "value": "get"
      },
      "scope": {
        "className": {
          "mode": "regex",
          "value": "(DistributedKVStore|distributedKVStore|KVStore|SingleKVStore)"
        }
      },
      "sourceKind": "call_return",
      "target": {
        "endpoint": "result"
      }
    },
