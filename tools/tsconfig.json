{
    "compilerOptions": {
        "target": "ES2021",
        "module": "CommonJS",
        "outDir": "../out/tools",
        "rootDir": ".",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "declaration": true,
        "resolveJsonModule": true,
        "moduleResolution": "node"
    },
    "include": [
        "./**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}
