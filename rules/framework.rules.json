{
  "schemaVersion": "1.1",
  "meta": {
    "name": "arktaint-harmony-framework-rules",
    "description": "Framework-level source/sink/transfer rules for HarmonyOS threat-oriented coverage (T1-T7).",
    "updatedAt": "2026-03-01"
  },
  "sources": [
    {
      "id": "source.harmony.router.getParams.exact",
      "enabled": true,
      "family": "source.harmony.router.getParams",
      "tier": "A",
      "kind": "call_return",
      "description": "Exact probe signature for router.getParams() (Tier A).",
      "match": {
        "kind": "callee_signature_equals",
        "value": "@sdk_signature_probe/taint_mock.ts: Router.getParams()"
      },
      "targetRef": {
        "endpoint": "result"
      },
      "tags": [
        "harmony",
        "phase7",
        "router",
        "probe_exact"
      ]
    },
    {
      "id": "source.harmony.router.getParams",
      "enabled": true,
      "family": "source.harmony.router.getParams",
      "tier": "B",
      "kind": "call_return",
      "description": "Treat router.getParams() return value as untrusted page input.",
      "match": {
        "kind": "signature_contains",
        "value": "Router.getParams"
      },
      "targetRef": {
        "endpoint": "result"
      },
      "tags": [
        "harmony",
        "phase7",
        "router"
      ]
    },
    {
      "id": "source.harmony.router.getParams.fallback",
      "enabled": true,
      "family": "source.harmony.router.getParams",
      "tier": "C",
      "kind": "call_return",
      "description": "Fallback: method-level getParams source with router class scope.",
      "match": {
        "kind": "method_name_equals",
        "value": "getParams"
      },
      "scope": {
        "className": {
          "mode": "regex",
          "value": "(Router|router|NavPathStack)"
        }
      },
      "targetRef": {
        "endpoint": "result"
      },
      "tags": [
        "harmony",
        "phase7",
        "router",
        "fallback"
      ]
    },
